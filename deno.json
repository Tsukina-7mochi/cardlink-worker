{
  "compilerOptions": {
    "lib": [
      "ESNext",
      "deno.window"
    ]
  },
  "tasks": {
    "build": "deno -RWE --allow-run build.ts",
    "cf-typegen": "deno wrangler types",
    "deploy": "deno wrangler deploy",
    "dev": "deno serve src/mod.ts",
    "dev-wrangler": "deno wrangler dev"
  },
  "imports": {
    "@deno/esbuild-plugin": "jsr:@deno/esbuild-plugin@^1.2.1",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/yaml": "jsr:@std/yaml@^1.0.12",
    "esbuild": "npm:esbuild@^0.27.3",
    "wrangler": "npm:wrangler@^4.69.0"
  }
}
