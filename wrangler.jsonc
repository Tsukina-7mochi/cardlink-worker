{
  "$schema": "https://unpkg.com/wrangler/config-schema.json",
  "name": "cardlink-worker",
  "main": "dist/server.js",
  "compatibility_date": "2026-02-27",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./public",
    "not_found_handling": "none"
  },
  "build": {
    "command": "deno task build"
  },
  "workers_dev": false,
  "routes": [
    {
      "pattern": "cardlink.ts7m.net",
      "custom_domain": true
    }
  ]
}
